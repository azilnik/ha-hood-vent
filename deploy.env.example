# Copy to deploy.env (gitignored) and fill in. Used by scripts/deploy.sh.

# SSH host alias (from ~/.ssh/config) or user@host of the machine running HA.
NAS_SSH_HOST=synology

# A writable staging dir on the NAS (SSH user must own it).
NAS_STAGING=/volume1/docker

# The packages directory INSIDE the HA container.
HA_CONFIG_PACKAGES=/config/packages

# Base URL of your Home Assistant.
HA_URL=https://ha.zilnik.me

# Long-lived access token: HA > Profile > Security > Long-lived access tokens.
HA_TOKEN=paste-your-long-lived-token-here
